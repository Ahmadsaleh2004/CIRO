# CIRO Store — Apache Configuration

# ── Directory Listing OFF ─────────────────────────────────────
Options -Indexes

# ── حماية الملفات الحساسة ─────────────────────────────────────
<FilesMatch "\.(sql|env|log|json)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# منع الوصول المباشر للمجلدات الحساسة
<IfModule mod_rewrite.c>
    RewriteEngine On

    # منع الوصول لـ config وhelpers وbackups من خارج PHP
    RewriteRule ^Task\(1\)/config/.*$              - [F,L]
    RewriteRule ^Task\(1\)/helpers/.*$             - [F,L]
    RewriteRule ^Task\(1\)/backups/.*$             - [F,L]
</IfModule>

# ── إعادة توجيه 404 ───────────────────────────────────────────
# ErrorDocument 404 /Task(1)/pages/404.php

# ── PHP Settings ─────────────────────────────────────────────
<IfModule mod_php.c>
    php_flag  display_errors        Off
    php_value upload_max_filesize   5M
    php_value post_max_size         6M
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode 1
</IfModule>

# ── Cache للأصول الثابتة ─────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg           "access plus 1 month"
    ExpiresByType image/png            "access plus 1 month"
    ExpiresByType image/webp           "access plus 1 month"
    ExpiresByType text/css             "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# ── Gzip Compression ─────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>
